# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Roboflow API key — get from https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=your_api_key_here

# Full Roboflow inference URL for your model.
# Example: https://detect.roboflow.com/liver-us-hcc/1
# The API key will be appended as ?api_key=...
ROBOFLOW_MODEL_URL=https://detect.roboflow.com/your-model/1

# Request timeout in seconds for Roboflow inference calls (default: 30)
ROBOFLOW_TIMEOUT=30

# Allowed origins for CORS (comma-separated).
# Use * for development; restrict in production.
CORS_ORIGINS=http://localhost:3000
